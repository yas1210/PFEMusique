import sys
import cv2
import os
from PyQt6.QtWidgets import QApplication
from PyQt6.QtCore import QTimer, QPoint
from core.audio import MidiManager
from core.engine import PoseEngine
from core.models import InteractiveSquare
from core.user_manager import UserManager
from ui.main_window import MainWindow
from ui.login_dialog import LoginDialog


class AppController:
    def __init__(self):
        self.app = QApplication(sys.argv)
        self.midi = MidiManager()
        self.engine = PoseEngine()
        
        # Initialize user manager
        data_dir = os.path.join(os.path.dirname(__file__), "data")
        self.user_manager = UserManager(data_dir)
        
        # Create main window with user_manager
        self.window = MainWindow(self.midi, self.engine, self.user_manager)
        
        self.cap = cv2.VideoCapture(0)

        # Timer pour la boucle principale
        self.timer = QTimer()
        self.timer.timeout.connect(self.run_loop)
        self.timer.start(30)

    def run_loop(self):
        ret, frame = self.cap.read()
        if not ret:
            return

        frame = cv2.flip(frame, 1)
        frame = cv2.resize(frame, (640, 480))
        h, w, _ = frame.shape

        # Mode sélectionné dans l'UI
        current_text = self.window.mode_combo.currentText()
        mode_key = self.window.mode_map.get(current_text, "MAINS")

        # Mediapipe
        results = self.engine.process_frame(frame)
        points = self.engine.get_landmarks_pixels(results, w, h, mode=mode_key)

        # Etat jeu / édition
        is_playing = not self.window.config_panel.isVisible()

        # Préparer les carrés actifs
        active_squares = []

        # Vérifier collision + dessiner les carrés
        for sq in self.window.squares:

            # Collision : vérifier si un point touche le carré
            sq.is_active = any(
                sq.rect.contains(QPoint(p[0], p[1])) for p in points
            )

            if sq.is_active:
                active_squares.append(sq)

            # Dessin du carré (gère coins + bouton delete)
            sq.draw(frame, show_controls=not is_playing)

        # MIDI : passer la liste complète des carrés pour gérer l'arrêt des sons
        self.midi.update_notes(active_squares, all_squares=self.window.squares)

        # Affichage final
        self.window.update_video_display(frame, points, show_points=True)

    def show_login_dialog(self):
        """Afficher le dialogue de connexion avant la fenêtre principale."""
        dialog = LoginDialog(self.user_manager, self.window)
        if dialog.exec():
            # Connexion réussie - sélectionner automatiquement le profil musicothérapeute
            success, message = self.user_manager.switch_to_musicotherapist_profile()
            print(f"✓ Profil musicothérapeute sélectionné: {self.user_manager.get_current_profile_name()}")
            
            # Rafraîchir l'affichage du profil et charger les configurations
            self.window.update_profile_label()
            self.window.charger_configs_du_disque()
            
            return True
        else:
            # Utilisateur a fermé la fenêtre de dialogue sans se connecter
            return False

    def exec(self):
        # Show login dialog first
        if not self.show_login_dialog():
            # User didn't login, exit application
            self.cap.release()
            self.midi.close()
            sys.exit(0)
        
        # Show main window after successful login
        self.window.show()
        res = self.app.exec()
        self.cap.release()
        self.midi.close()
        sys.exit(res)


if __name__ == "__main__":
    controller = AppController()
    controller.exec()
