import sys
import cv2
import mediapipe as mp
from PyQt6.QtWidgets import QApplication, QLabel, QWidget, QVBoxLayout, QHBoxLayout, QPushButton, QColorDialog, QSpinBox, QComboBox, QFormLayout
from PyQt6.QtGui import QImage, QPixmap, QColor, QMouseEvent, QPainter
from PyQt6.QtCore import QTimer, QRect, Qt, QPoint
import pygame.midi


# initialise la librairie MIDI de  de pygame qui contient les fichiers de son
pygame.midi.init()
player = pygame.midi.Output(0)
sound_playing = {}

 
# initialise MediaPipe
mp_pose = mp.solutions.pose
mp_drawing = mp.solutions.drawing_utils

# Donne des noms qux notes de MIDI parcequ'autrement le do c'est 60, le ré c'est un autre num etc.
NOTE_NAMES = ["Do","Do#","Ré","Ré#","Mi","Fa","Fa#","Sol","Sol#","La","La#","Si"]
NOTE_TO_OFFSET = {name: i for i,name in enumerate(NOTE_NAMES)}

# Couleurs par défaut selon la note
DEFAULT_NOTE_COLORS = {
    0: QColor(255,0,0),
    1: QColor(255,128,0),
    2: QColor(255,255,0),
    3: QColor(128,255,0),
    4: QColor(0,255,0),
    5: QColor(0,255,128),
    6: QColor(0,255,255),
    7: QColor(0,128,255),
    8: QColor(0,0,255),
    9: QColor(128,0,255),
    10: QColor(255,0,255),
    11: QColor(255,0,128)
}

#Défini le bouton de config pour pouvoir mettre verticalement mais ne marche pas encore
class FlippedButton(QPushButton):
    def __init__(self, text, parent=None):
        super().__init__(text, parent)

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.translate(self.width()/2, self.height()/2)
        painter.rotate(-90)
        painter.translate(-self.width()/2, -self.height()/2)
        super().paintEvent(event)

 #defini les carrés interactifs qu'on ajoute sur l'écran
class InteractiveSquare:
    HANDLE_SIZE = 10
    POINT_RADIUS = 5
    DELETE_SIZE = 12

    def __init__(self, x1, y1, x2, y2, color=QColor(255,0,0), note=60):
        self.rect = QRect(x1, y1, x2-x1, y2-y1)
        self.color = color
        self.note = note
        self.dragging = False
        self.resizing = False
        self.resize_dir = None
        self.offset = QPoint()

    def handle_at(self, pos: QPoint):
        rect = self.rect
        handles = {
            "top_left": QRect(rect.topLeft(), QPoint(rect.topLeft().x()+self.HANDLE_SIZE, rect.topLeft().y()+self.HANDLE_SIZE)),
            "top_right": QRect(rect.topRight()-QPoint(self.HANDLE_SIZE,0), QPoint(rect.topRight().x()+1, rect.topRight().y()+self.HANDLE_SIZE)),
            "bottom_left": QRect(rect.bottomLeft()-QPoint(0,self.HANDLE_SIZE), QPoint(rect.bottomLeft().x()+self.HANDLE_SIZE, rect.bottomLeft().y()+1)),
            "bottom_right": QRect(rect.bottomRight()-QPoint(self.HANDLE_SIZE,self.HANDLE_SIZE), rect.bottomRight())
        }
        for dir, handle_rect in handles.items():
            if handle_rect.contains(pos):
                return dir
        return None

    def delete_at(self, pos: QPoint):
        rect = QRect(self.rect.topRight()-QPoint(self.DELETE_SIZE,0),
                     QPoint(self.rect.topRight().x(), self.rect.topRight().y()+self.DELETE_SIZE))
        return rect.contains(pos)

 # defini la fenetre de video detectée par la webcam
class CameraWindow(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("MPipophone")
        self.resize(1000, 600)

        layout = QHBoxLayout()
        self.setLayout(layout)

        # config du label de pannel de video
        self.video_label = QLabel()
        self.video_label.setMinimumSize(640, 480)
        self.video_label.setScaledContents(True)
        layout.addWidget(self.video_label, stretch=1)

        # Pannel de config
        self.config_panel = QWidget()
        self.config_panel.setFixedWidth(300)
        layout.addWidget(self.config_panel)
        self.config_layout = QFormLayout()
        self.config_panel.setLayout(self.config_layout)

        # config de l'affichage du color picker
        self.color_btn = QPushButton("Choisir couleur")
        self.color_btn.clicked.connect(self.choose_color)
        self.config_layout.addRow("Couleur :", self.color_btn)
        self.current_color = None

        # config de l'affichage du choix de note et octave
        self.note_combo = QComboBox()
        self.note_combo.addItems(NOTE_NAMES)
        self.config_layout.addRow("Note :", self.note_combo)

        self.octave_spin = QSpinBox()
        self.octave_spin.setRange(1,7)
        self.octave_spin.setValue(4)
        self.config_layout.addRow("Octave :", self.octave_spin)

        # config bouton ajouter carré
        self.add_btn = QPushButton("Ajouter carré")
        self.add_btn.clicked.connect(self.add_square)
        self.config_layout.addRow(self.add_btn)

        # config du bouton start pour minimiser la fenetre de config
        self.start_btn = QPushButton("Démarrer / Minimiser")
        self.start_btn.clicked.connect(self.toggle_config_panel)
        self.config_layout.addRow(self.start_btn)
        self.config_minimized = False

        # confid du boutton "config" minimisé qui permettra de retomber sur la fenetre config principale
        self.dock_btn = FlippedButton("Config")
        self.dock_btn.setFixedWidth(70)
        self.dock_btn.setFixedHeight(480)
        layout.addWidget(self.dock_btn, alignment=Qt.AlignmentFlag.AlignRight)
        self.dock_btn.hide()
        self.dock_btn.clicked.connect(self.restore_config)

        # Liste des carrés interactifs
        self.squares = []

        # init de la webcam avec mediapipe
        self.cap = cv2.VideoCapture(0)
        self.pose = mp_pose.Pose()
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_frame)
        self.timer.start(30)

        # init de la fonction drag et redimensionnement des carrés 
        self.active_square = None
        self.video_label.setMouseTracking(True)
        self.video_label.mousePressEvent = self.mouse_press
        self.video_label.mouseMoveEvent = self.mouse_move
        self.video_label.mouseReleaseEvent = self.mouse_release

     
     # Les équivalents des events listeners et compagnie
    def choose_color(self):
        color = QColorDialog.getColor()
        if color.isValid():
            self.current_color = color

    def add_square(self):
        note_name = self.note_combo.currentText()
        octave = self.octave_spin.value()
        midi_note = 12*(octave+1) + NOTE_TO_OFFSET[note_name]

        if self.current_color is None:
            color = DEFAULT_NOTE_COLORS[NOTE_TO_OFFSET[note_name]]
        else:
            color = self.current_color

        sq = InteractiveSquare(100,100,200,200,color,midi_note)
        self.squares.append(sq)

    def toggle_config_panel(self):
        if not self.config_minimized:
            self.config_panel.hide()
            self.dock_btn.show()
            self.config_minimized = True
        else:
            self.restore_config()

    def restore_config(self):
        self.config_panel.show()
        self.dock_btn.hide()
        self.config_minimized = False

     
    def _scale_mouse_pos(self, event):
        label_w = self.video_label.width()
        label_h = self.video_label.height()
        scale_x = 640 / label_w
        scale_y = 480 / label_h
        pos = event.position().toPoint()
        return QPoint(int(pos.x() * scale_x), int(pos.y() * scale_y))

    def mouse_press(self, event: QMouseEvent):
        if self.config_minimized:
            return

        pos = self._scale_mouse_pos(event)

        for sq in reversed(self.squares):
            if sq.delete_at(pos):
                self.squares.remove(sq)
                return
            handle = sq.handle_at(pos)
            if handle:
                sq.resizing = True
                sq.resize_dir = handle
                self.active_square = sq
                return
            elif sq.rect.contains(pos):
                sq.dragging = True
                sq.offset = pos - sq.rect.topLeft()
                self.active_square = sq
                return

    def mouse_move(self, event: QMouseEvent):
        if not self.active_square or self.config_minimized:
            return

        pos = self._scale_mouse_pos(event)
        sq = self.active_square

        if sq.dragging:
            sq.rect.moveTopLeft(pos - sq.offset)
        elif sq.resizing:
            if sq.resize_dir == "top_left":
                sq.rect.setTopLeft(pos)
            elif sq.resize_dir == "top_right":
                sq.rect.setTopRight(pos)
            elif sq.resize_dir == "bottom_left":
                sq.rect.setBottomLeft(pos)
            elif sq.resize_dir == "bottom_right":
                sq.rect.setBottomRight(pos)

    def mouse_release(self, event: QMouseEvent):
        if self.active_square:
            self.active_square.dragging = False
            self.active_square.resizing = False
            self.active_square = None

     
    def update_frame(self):
        global sound_playing
        ret, frame = self.cap.read()
        if not ret: return
        frame = cv2.flip(frame,1)
        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        results = self.pose.process(rgb)
        h,w,_ = frame.shape

        if results.pose_landmarks:
            mp_drawing.draw_landmarks(frame, results.pose_landmarks, mp_pose.POSE_CONNECTIONS)

        for sq in self.squares:
            x, y, width, height = sq.rect.x(), sq.rect.y(), sq.rect.width(), sq.rect.height()
            cv2.rectangle(frame,(x,y),(x+width,y+height),(sq.color.red(), sq.color.green(), sq.color.blue()),2)

            if not self.config_minimized:
                corners = [sq.rect.topLeft(), sq.rect.topRight(), sq.rect.bottomLeft(), sq.rect.bottomRight()]
                for corner in corners:
                    cv2.circle(frame,(corner.x(),corner.y()),InteractiveSquare.POINT_RADIUS,(0,255,0),-1)
                top_right = sq.rect.topRight()
                cv2.rectangle(frame,(top_right.x()-InteractiveSquare.DELETE_SIZE,top_right.y()),
                              (top_right.x(), top_right.y()+InteractiveSquare.DELETE_SIZE),(0,0,255),-1)
                cv2.putText(frame,"X",(top_right.x()-InteractiveSquare.DELETE_SIZE+2,top_right.y()+InteractiveSquare.DELETE_SIZE-2),
                            cv2.FONT_HERSHEY_SIMPLEX,0.5,(255,255,255),1)

            active = False
            if results.pose_landmarks:
                for lm in results.pose_landmarks.landmark:
                    cx, cy = int(lm.x*w), int(lm.y*h)
                    if sq.rect.contains(cx,cy):
                        active=True
                        break

            if active and not sound_playing.get(sq.note, False):
                player.note_on(sq.note,127)
                sound_playing[sq.note]=True
            elif not active and sound_playing.get(sq.note,False):
                player.note_off(sq.note,127)
                sound_playing[sq.note]=False

        image = QImage(frame.data,w,h,3*w,QImage.Format.Format_RGB888)
        self.video_label.setPixmap(QPixmap.fromImage(image))
        
    def closeEvent(self,event):
        self.timer.stop()
        self.cap.release()
        cv2.destroyAllWindows()
        for note,playing in sound_playing.items():
            if playing:
                player.note_off(note,127)
        player.close()
        pygame.midi.quit()
        event.accept()

 
if __name__=="__main__":
    app = QApplication([])
    window = CameraWindow()
    window.show()
    sys.exit(app.exec())